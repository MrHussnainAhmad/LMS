{
    admin :2019
}

http:// {
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    reverse_proxy {
        to app:3000 app2:3000
        lb_policy round_robin

        health_uri /api/health
        health_interval 10s
        health_timeout 3s
        health_fails 2
        health_passes 1

        fail_duration 30s
        max_fails 1
        unhealthy_status 5xx
    }
}
