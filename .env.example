# Copy this file to .env and fill in real values.
# Never commit real credentials.

# Database
DATABASE_URL="postgres://app:YOUR_POSTGRES_PASSWORD@pgbouncer:6432/app"
DIRECT_URL="postgres://app:YOUR_POSTGRES_PASSWORD@postgres:5432/app"

# Redis Cache
REDIS_URL="redis://valkey:6379"

# Security
JWT_SECRET="replace-with-a-long-random-secret"

# Cloudinary (Used for image uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email (Used for notifications/resets)
GMAIL_USER="your-email@example.com"
GMAIL_APP_PASSWORD="your-app-password"
